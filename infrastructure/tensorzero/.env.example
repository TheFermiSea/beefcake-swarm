# TensorZero environment variables
# Copy to .env and fill in values.

# CLIAPIProxy API key (same as SWARM_CLOUD_API_KEY in ~/.bashrc)
SWARM_CLOUD_API_KEY=your-api-key-here

# TensorZero Autopilot API key (from autopilot.tensorzero.com)
# Enables cloud-based prompt optimization, eval management, and A/B testing.
TENSORZERO_AUTOPILOT_API_KEY=sk-t0-your-key-here
