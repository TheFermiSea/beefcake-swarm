{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "issue_id": { "type": "string", "description": "Beads issue ID" },
    "objective": { "type": "string", "description": "Task description / issue title" },
    "error_context": { "type": "string", "description": "Compiler errors or previous iteration context" },
    "iteration": { "type": "integer", "description": "Current iteration number (1-based)" },
    "previous_result": { "type": "string", "description": "Summary of previous iteration result" }
  },
  "required": ["issue_id", "objective"],
  "additionalProperties": false
}
