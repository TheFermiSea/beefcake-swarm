#!/usr/bin/env bash
# .beads/hooks/on_update — Log status transitions for observability.
# Receives JSON issue data on stdin from beads.
#
# Appends a structured JSON line to $REPO_ROOT/.swarm-hook-events.jsonl
# when an issue is updated, capturing status transitions.
#
# Fails silently — hooks must never block the beads CLI.

set -o pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
EVENT_LOG="${REPO_ROOT}/.swarm-hook-events.jsonl"

# Read stdin (beads pipes issue JSON)
INPUT="$(cat)" || exit 0
[ -z "$INPUT" ] && exit 0

# Extract fields
if command -v jq >/dev/null 2>&1; then
  ISSUE_ID="$(printf '%s' "$INPUT" | jq -r '.id // .task_ref // "unknown"')"
  TITLE="$(printf '%s' "$INPUT" | jq -r '.title // "untitled"')"
  STATUS="$(printf '%s' "$INPUT" | jq -r '.status // "unknown"')"
  ACTOR="$(printf '%s' "$INPUT" | jq -r '.actor // .assigned_to // env.BD_ACTOR // "unknown"')"
  TIMESTAMP="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '%s\n' "$(jq -n \
    --arg ts "$TIMESTAMP" \
    --arg ev "issue.updated" \
    --arg id "$ISSUE_ID" \
    --arg title "$TITLE" \
    --arg status "$STATUS" \
    --arg actor "$ACTOR" \
    '{timestamp: $ts, event: $ev, issue_id: $id, title: $title, status: $status, actor: $actor}')" \
    >> "$EVENT_LOG" 2>/dev/null
else
  # Fallback: best-effort extraction without jq
  ISSUE_ID="$(printf '%s' "$INPUT" | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  [ -z "$ISSUE_ID" ] && ISSUE_ID="unknown"
  TITLE="$(printf '%s' "$INPUT" | sed -n 's/.*"title"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  [ -z "$TITLE" ] && TITLE="untitled"
  STATUS="$(printf '%s' "$INPUT" | sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  [ -z "$STATUS" ] && STATUS="unknown"
  ACTOR="${BD_ACTOR:-unknown}"
  TIMESTAMP="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '{"timestamp":"%s","event":"issue.updated","issue_id":"%s","title":"%s","status":"%s","actor":"%s"}\n' \
    "$TIMESTAMP" "$ISSUE_ID" "$TITLE" "$STATUS" "$ACTOR" \
    >> "$EVENT_LOG" 2>/dev/null
fi

exit 0
